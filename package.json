{
  "name": "royal-shape-backend-service",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "check-node-version": "node -e \"if (!/^v22\\./.test(process.version)) { console.error('You must run the project with Node v22, thank you!'); process.exit(1); }\"",
    "copy-templates": "copyfiles -u 1 \"src/templates/**/*\" dist/src",
    "copy-config": "copyfiles -u 1 \"config/**/*\" dist/",
    "replace-punycode": "find ./node_modules -type f -exec sed -i 's/require(\"punycode\")/require(\"punycode\\/\")/g' {} +",
    "preinstall": "npm run check-node-version",
    "prestart": "npm run check-node-version",
    "start": "tsc && node --trace-deprecation dist/src/index.js",
    "prebuild": "npm run check-node-version && npm run replace-punycode",
    "build": "tsc --build",
    "postbuild": "npm run copy-templates && npm run copy-config",
    "vercel-build": "npm run check-node-version && npm run replace-punycode && tsc --build && npm run copy-templates && npm run copy-config",
    "vercel-postbuild": "echo 'Build completed for Vercel'",
    "dev": "nodemon",
    "lint": "eslint",
    "lint:fix": "eslint src/**/*.ts --ext .ts --fix",
    "lint-staged": "lint-staged",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.25.0",
    "@types/config": "^3.3.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/lodash": "^4.17.16",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.1",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "copyfiles": "^2.4.1",
    "eslint": "^9.25.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-import-resolver-typescript": "^4.3.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.6",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "nodemon": "^3.1.9",
    "pinst": "^3.0.0",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1"
  },
  "dependencies": {
    "@typegoose/typegoose": "^12.14.0",
    "argon2": "^0.41.1",
    "axios": "^1.8.4",
    "config": "^3.3.12",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "firebase-admin": "^13.2.0",
    "helmet": "^8.1.0",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mongoose": "~8.13.2",
    "multer": "1.4.5-lts.2",
    "nodemailer": "^6.10.1",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "zod": "^3.24.3"
  },
  "lint-staged": {
    "*.js": "eslint --fix",
    "*.{js,css,md}": "prettier --write"
  }
}
